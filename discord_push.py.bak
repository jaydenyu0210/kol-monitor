"""
Discord Push Notifications - Sends KOL monitoring updates to Discord via webhooks.
"""
import json
import os
import time
import urllib.request
from datetime import datetime, timedelta

import psycopg2
import psycopg2.extras

DB_DSN = "dbname=kol_monitor host=/tmp"
CONFIG_PATH = "/data/.openclaw/workspace/kol-monitor/discord_webhooks.json"

def load_webhooks():
    with open(CONFIG_PATH) as f:
        return json.load(f)

def send_discord(webhook_url, embed):
    if not webhook_url:
        print(f"  ⚠️ Missing webhook for embed, skipping send")
        return False
    
    data = {"username": "KOL Monitor", "avatar_url": "https://i.imgur.com/g91gVAM.png", "embeds": [embed]}
    headers = {'Content-Type': 'application/json', 'User-Agent': 'Mozilla/5.0'}
    
    try:
        req = urllib.request.Request(webhook_url, data=json.dumps(data).encode('utf-8'), headers=headers)
        resp = urllib.request.urlopen(req, timeout=15)
        if not (200 <= resp.status < 300):
            print(f"  ❌ Discord send error: {resp.status} {resp.read().decode()}")
        return 200 <= resp.status < 300
    except Exception as e:
        print(f"  ❌ Discord send error: {e}")
        return False

def get_db():
    return psycopg2.connect(DB_DSN)

def push_new_posts(webhooks, since_minutes):
    db = get_db()
    cur = db.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
    
    cur.execute("""
        SELECT p.*, k.name as kol_name, k.category, 'Twitter' as platform FROM twitter_posts p
        JOIN kols k ON k.id = p.kol_id WHERE p.is_notified = FALSE
        ORDER BY p.captured_at ASC
    """)
    
    posts = cur.fetchall()
    db.close()
    
    if not posts: 
        print("  - No new posts to push.")
        embed = {
            "title": "No New Tweets",
            "description": f"Checked all monitored KOLs in the last {since_minutes} minutes.\\n**No change** detected.",
            "color": 0x64748B,
            "timestamp": datetime.now().isoformat()
        }
        send_discord(webhooks.get('posts'), embed)
        return
    
    print(f"  - Found {len(posts)} new posts to push.")
    for post in posts:
        color = 0x1DA1F2 # Twitter blue
        embed = {
            "title": f"New Tweet from {post['kol_name']}",
            "url": post.get('post_url'),
            "description": (post['content'][:1024] if post['content'] else "No content."),
            "color": color,
            "fields": [
                {"name": "Likes", "value": str(post['likes'] or 0), "inline": True},
                {"name": "Retweets", "value": str(post.get('reposts', 0)), "inline": True},
            ],
            "footer": {"text": f"Category: {post['category'] or 'N/A'}"},
            "timestamp": datetime.now().isoformat() 
        }
        if send_discord(webhooks.get('posts'), embed):
            db = get_db()
            cur = db.cursor()
            cur.execute("UPDATE twitter_posts SET is_notified = TRUE WHERE id = %s", (post['id'],))
            db.commit()
            db.close()
        time.sleep(2)

def push_follower_updates(webhooks, since_minutes):
    db = get_db()
    cur = db.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
    
    cur.execute("SELECT id, name, twitter_url, linkedin_url FROM kols WHERE status='active'")
    kols = cur.fetchall()
    
    description_lines = []
    has_changes = False
    time_threshold = datetime.now() - timedelta(minutes=since_minutes)
    
    for kol in kols:
        cur.execute("""
            SELECT followers_count, captured_at 
            FROM kol_metrics 
            WHERE kol_id = %s AND platform = 'twitter'
            ORDER BY captured_at DESC LIMIT 2
        """, (kol['id'],))
        records = cur.fetchall()
        
        if not records: continue
        
        latest = records[0]
        prev = records[1] if len(records) > 1 else latest
        
        if latest['captured_at'] >= time_threshold:
            f_diff = (latest['followers_count'] or 0) - (prev['followers_count'] or 0)
            
            if f_diff != 0:
                has_changes = True
                f_str = f"+{f_diff}" if f_diff > 0 else f"{f_diff}"
                f_display = f"{latest['followers_count']:,} ({f_str})"
                
                line = f"**[{kol['name']}]({kol['twitter_url'] or kol['linkedin_url']})**: 👥 Followers: {f_display}\\n↳ *Accounts changed: [Requires advanced scraping, currently only tracks numerical counts]*"
                description_lines.append(line)
    
    db.close()

    if not has_changes:
        print("  - No follower changes to push.")
        embed = {
            "title": "KOL Follower Update",
            "description": f"Checked all monitored KOLs in the last {since_minutes} minutes.\\n**No change** detected.",
            "color": 0x64748B,
            "timestamp": datetime.now().isoformat()
        }
        send_discord(webhooks.get('followers'), embed)
        return

    print(f"  - Found {len(description_lines)} follower updates to push.")
    embed = {
        "title": "📈 KOL Follower Update (Changes Detected)",
        "description": "\\n\\n".join(description_lines[:20]),
        "color": 0x3B82F6,
        "footer": {"text": f"{len(description_lines)} KOLs had follower changes"},
        "timestamp": datetime.now().isoformat()
    }
    send_discord(webhooks.get('followers'), embed)


def push_following_updates(webhooks, since_minutes):
    db = get_db()
    cur = db.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
    
    cur.execute("SELECT id, name, twitter_url, linkedin_url FROM kols WHERE status='active'")
    kols = cur.fetchall()
    
    description_lines = []
    has_changes = False
    time_threshold = datetime.now() - timedelta(minutes=since_minutes)
    
    for kol in kols:
        cur.execute("""
            SELECT following_count, captured_at 
            FROM kol_metrics 
            WHERE kol_id = %s AND platform = 'twitter'
            ORDER BY captured_at DESC LIMIT 2
        """, (kol['id'],))
        records = cur.fetchall()
        
        if not records: continue
        
        latest = records[0]
        prev = records[1] if len(records) > 1 else latest
        
        if latest['captured_at'] >= time_threshold:
            fi_diff = (latest['following_count'] or 0) - (prev['following_count'] or 0)
            
            if fi_diff != 0:
                has_changes = True
                fi_str = f"+{fi_diff}" if fi_diff > 0 else f"{fi_diff}"
                fi_display = f"{latest['following_count']:,} ({fi_str})"
                
                line = f"**[{kol['name']}]({kol['twitter_url'] or kol['linkedin_url']})**: 🔗 Following: {fi_display}\\n↳ *Accounts changed: [Requires advanced scraping, currently only tracks numerical counts]*"
                description_lines.append(line)
    
    db.close()

    if not has_changes:
        print("  - No following changes to push.")
        embed = {
            "title": "KOL Following Update",
            "description": f"Checked all monitored KOLs in the last {since_minutes} minutes.\\n**No change** detected.",
            "color": 0x64748B,
            "timestamp": datetime.now().isoformat()
        }
        send_discord(webhooks.get('following'), embed)
        return

    print(f"  - Found {len(description_lines)} following updates to push.")
    embed = {
        "title": "📈 KOL Following Update (Changes Detected)",
        "description": "\\n\\n".join(description_lines[:20]),
        "color": 0x10B981,
        "footer": {"text": f"{len(description_lines)} KOLs had following changes"},
        "timestamp": datetime.now().isoformat()
    }
    send_discord(webhooks.get('following'), embed)



def push_heatmap_update(webhooks):
    print("  - Pushing heatmap update notice to Discord.")
    db = get_db()
    cur = db.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
    
    # Get posts updated in the last 65 minutes
    cur.execute("""
        SELECT p.*, k.name as kol_name, k.twitter_url 
        FROM twitter_posts p
        JOIN kols k ON k.id = p.kol_id
        WHERE p.captured_at >= NOW() - INTERVAL '65 minutes'
    """)
    posts = cur.fetchall()
    db.close()
    
    significant_posts = []
    for p in posts:
        # Avoid treating brand new posts as significant changes (last_likes == likes on insert)
        delta_views = (p['views'] or 0) - (p['last_views'] or 0)
        delta_likes = (p['likes'] or 0) - (p['last_likes'] or 0)
        delta_reposts = (p['reposts'] or 0) - (p['last_reposts'] or 0)
        delta_bookmarks = (p['bookmarks'] or 0) - (p['last_bookmarks'] or 0)
        
        # Threshold for significance
        if (delta_views > 1000 or delta_likes > 20 or delta_reposts >= 5 or delta_bookmarks >= 3) and p['last_views'] != p['views']:
            significant_posts.append((p, delta_views, delta_likes, delta_reposts, delta_bookmarks))
    
    if not significant_posts:
        embed = {
            "title": "🔥 X KOL Posts Heatmap Updated",
            "description": "The Bubble Heatmap has been refreshed.\n\n**No significant changes found** in existing posts over the last hour.\n\n**[Click here to view the Dashboard](http://187.124.224.226:3000)**",
            "color": 0x64748B,
            "timestamp": datetime.now().isoformat()
        }
        send_discord(webhooks.get('heatmap'), embed)
        return

    # Sort by highest engagement gain (delta_likes + delta_reposts*2 + delta_bookmarks*3)
    significant_posts.sort(key=lambda x: x[2] + x[3]*2 + x[4]*3, reverse=True)
    
    fields = []
    for sp in significant_posts[:5]:  # top 5
        p, dv, dl, dr, db_mk = sp
        changes = []
        if dv > 0: changes.append(f"+{dv} Views")
        if dl > 0: changes.append(f"+{dl} Likes")
        if dr > 0: changes.append(f"+{dr} Reposts")
        if db_mk > 0: changes.append(f"+{db_mk} Bookmarks")
        
        text_preview = (p['content'] or '')[:60].replace('\n', ' ') + '...'
        fields.append({
            "name": f"{p['kol_name']} ({', '.join(changes)})",
            "value": f"[{text_preview}]({p['post_url']})",
            "inline": False
        })

    embed = {
        "title": "🔥 X KOL Posts Heatmap: Significant Changes Detected",
        "description": f"The Bubble Heatmap has been refreshed. Found **{{len(significant_posts)}}** posts with a surge in engagement!\n\n**[Click here to view the Dashboard](http://187.124.224.226:3000)**",
        "color": 0xEF4444,
        "fields": fields,
        "footer": {"text": "Bubble sizes represent Engagement Rate. Colors represent Reposts+Bookmarks."},
        "timestamp": datetime.now().isoformat()
    }
    send_discord(webhooks.get('heatmap'), embed)

if __name__ == "__main__":

    import sys
    job_type = sys.argv[1] if len(sys.argv) > 1 else "all"
    minutes = int(sys.argv[2]) if len(sys.argv) > 2 else 60
    
    webhooks = load_webhooks()
    
    if job_type in ["posts", "all"]:
        print(f"📤 Pushing POSTS to Discord (last {minutes} min)...")
        push_new_posts(webhooks, minutes)
        
    if job_type in ["metrics", "all"]:
        print(f"📤 Pushing FOLLOWERS to Discord (last {minutes} min)...")
        push_follower_updates(webhooks, minutes)
        print(f"📤 Pushing FOLLOWING to Discord (last {minutes} min)...")
        push_following_updates(webhooks, minutes)
        
    if job_type in ["heatmap", "all"]:
        print(f"📤 Pushing HEATMAP notice to Discord...")
        push_heatmap_update(webhooks)
        
    print("✅ Push to Discord complete!")
