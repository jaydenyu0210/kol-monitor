# ============================================================
# KOL Monitor Pro — Environment Variables Template
# ============================================================
# Copy this file and fill in your values:
#   cp .env.template backend/.env
#   cp .env.template frontend/.env

# ============================================================
# BACKEND (Railway)
# ============================================================

# Supabase Database (use connection pooler, port 6543!)
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@db.xxxx.supabase.co:6543/postgres

# Supabase Auth
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Server
API_PORT=3000
FRONTEND_URL=https://your-app.vercel.app

# Playwright
HEADLESS=true
SCRAPE_INTERVAL_MINS=30

# ============================================================
# FRONTEND (Vercel)
# ============================================================

# Replace placeholders in frontend/js/supabaseClient.js
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...your-anon-key

# Replace placeholder in frontend/js/api.js
# RAILWAY_API_URL=https://your-app.up.railway.app
